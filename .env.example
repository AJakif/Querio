# Database
DATABASE_URL=postgresql://querio:querio@localhost:5432/querio

# Model provider — the model string used by Pydantic AI
# Examples: openai:gpt-4o-mini | claude-3-5-sonnet-latest | ollama:llama3
MODEL_NAME=openai:gpt-4o-mini

# API keys (only the one matching your provider is needed)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (only if MODEL_NAME starts with ollama:)
OLLAMA_BASE_URL=http://localhost:11434/v1
