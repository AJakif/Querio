# Database
DATABASE_URL=postgresql://querio:querio@localhost:5432/querio

# Target schema for dbt output tables (queried by the agent)
DB_SCHEMA=marts

# Model provider (used if OPENAI_API_KEY or ANTHROPIC_API_KEY is set)
MODEL_NAME=openai:gpt-4o-mini

# API keys (at least one required for real LLM queries)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
