# Runtime environment: dev or prod
APP_ENV=dev

# Database
DATABASE_URL=postgresql://querio:querio@localhost:5432/querio

# Target schema for dbt output tables (queried by the agent)
DB_SCHEMA=marts

# Model provider
# openai, claude, or ollama
MODEL_PROVIDER=openai
MODEL_NAME=openai:gpt-4o-mini
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional explicit log level override, e.g. DEBUG, INFO, WARNING
LOG_LEVEL=
QUERY_TIMEOUT_MS=5000

# Optional path to a local secrets file with API keys.
# See `.env.secrets.example`.
QUERIO_SECRETS_FILE=.env.secrets
