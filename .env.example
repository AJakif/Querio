# Runtime environment: dev or prod
APP_ENV=dev

# Database
DATABASE_URL=postgresql://querio:querio@localhost:5432/querio

# Load the bundled deterministic demo data. Keep false when using your own data.
SEED_DATABASE=false

# Target schema for dbt output tables (queried by the agent)
DB_SCHEMA=marts

# Model provider
# openai, claude, or ollama
MODEL_PROVIDER=openai
MODEL_NAME=openai:gpt-4o-mini
OLLAMA_MODEL=qwen2.5:7b
# Used by the Docker backend; localhost here would refer to the container.
OLLAMA_BASE_URL_DOCKER=http://host.docker.internal:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
# Context window (in tokens) requested from Ollama. The planner/aggregator prompts plus
# result rows can exceed Ollama's small default (2048), causing silent failures.
OLLAMA_NUM_CTX=8192

# Optional explicit log level override, e.g. DEBUG, INFO, WARNING
LOG_LEVEL=DEBUG
QUERY_TIMEOUT_MS=15000

# Optional path to a local secrets file with API keys.
# See `.env.secrets.example`.
QUERIO_SECRETS_FILE=.env.secrets
